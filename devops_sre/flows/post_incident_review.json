{
  "version": "1",
  "logical_key": "post_incident_review",
  "name": "Post-Incident Review",
  "description": "Produce a blameless PIR from incident context, telemetry evidence, and risk lessons learned.",
  "status": "draft",
  "alias_prefix": "ops",
  "approval_notes": [
    "Before publishing PIR to broad audience or customers",
    "Before closing related incident or problem tickets"
  ],
  "flow": {
    "start_node_id": "triage",
    "nodes": [
      {
        "id": "triage",
        "name": "Incident Recap",
        "type": "agent",
        "label": "Recap",
        "agent_alias": "ops_incident_triage_analyst",
        "input_mappings": []
      },
      {
        "id": "telemetry",
        "name": "Evidence Review",
        "type": "agent",
        "label": "Evidence",
        "agent_alias": "ops_logs_and_metrics_investigator",
        "input_mappings": [
          {
            "source_node_id": "triage",
            "source_path": "output_json",
            "target_field": "incident_recap"
          }
        ]
      },
      {
        "id": "lessons",
        "name": "Process & Change Lessons",
        "type": "agent",
        "label": "Lessons",
        "agent_alias": "ops_change_risk_analyst",
        "input_mappings": [
          {
            "source_node_id": "triage",
            "source_path": "output_json",
            "target_field": "incident_recap"
          },
          {
            "source_node_id": "telemetry",
            "source_path": "output_json",
            "target_field": "evidence"
          }
        ]
      },
      {
        "id": "pir",
        "name": "PIR Document",
        "type": "agent",
        "label": "PIR",
        "agent_alias": "ops_post_incident_review_writer",
        "input_mappings": [
          {
            "source_node_id": "triage",
            "source_path": "output_json",
            "target_field": "incident_recap"
          },
          {
            "source_node_id": "telemetry",
            "source_path": "output_json",
            "target_field": "evidence"
          },
          {
            "source_node_id": "lessons",
            "source_path": "output_json",
            "target_field": "process_lessons"
          }
        ]
      }
    ],
    "edges": [
      {"id": "e_tri_tel", "source": "triage", "target": "telemetry"},
      {"id": "e_tel_lessons", "source": "telemetry", "target": "lessons"},
      {"id": "e_lessons_pir", "source": "lessons", "target": "pir"}
    ]
  }
}
